#!/usr/bin/env bash
# load-secrets — source Moss API keys from secure location
#
# Usage:
#   eval "$(bin/load-secrets)"      # exports vars in current shell
#   source ~/.config/moss/secrets.env   # alternative direct source
#
# Or add to .bashrc:
#   [[ -f ~/.config/moss/secrets.env ]] && source ~/.config/moss/secrets.env

SECRETS_FILE="${HOME}/.config/moss/secrets.env"

if [ ! -f "$SECRETS_FILE" ]; then
  echo "Error: secrets file not found: $SECRETS_FILE" >&2
  echo "Create it with format:" >&2
  echo '  export SERPER_API_KEY="***"' >&2
  echo '  export EXA_API_KEY="***"' >&2
  exit 1
fi

# Print exports for eval
grep '^export ' "$SECRETS_FILE"