#!/usr/bin/env bash
# github-watchdog — alert on GITHUB_TOKEN expiry or breakage
#
# Cron: daily 09:00 UTC (after secrets-validate has caught any breakage)
#
# Exit codes:
#   0 = OK (token valid, >14 days remaining) or WARN (8-14 days, no alert)
#   1 = ALERT (≤7 days remaining OR token rejected)
#
# Requires:
#   GITHUB_TOKEN        in ~/.config/moss/secrets.env (validated by secrets-validate)
#   GITHUB_TOKEN_EXPIRES=YYYY-MM-DD (optional; if unset, no expiry alerts)
#
# 2026-06-23: initial version

set -euo pipefail
cd /root/.openclaw/workspace || exit 1

# Load secrets without polluting env (only GITHUB_TOKEN + GITHUB_TOKEN_EXPIRES)
SECRETS_FILE="${HOME}/.config/moss/secrets.env"
[ -r "$SECRETS_FILE" ] || { echo "ALERT: $SECRETS_FILE missing"; exit 1; }

# shellcheck disable=SC1090
source "$SECRETS_FILE"

[ -n "${GITHUB_TOKEN:-}" ] || { echo "ALERT: GITHUB_TOKEN unset in secrets.env"; exit 1; }

EXPIRES="${GITHUB_TOKEN_EXPIRES:-}"
NOW_TS=$(date -u +%s)

# 1. Live check (token must authenticate — 5000/h = auth OK, 60/h = anon/rejected)
LIVE_LIMIT=$(curl -sS --max-time 10 \
  -H "Authorization: Bearer $GITHUB_TOKEN" \
  -H "Accept: application/vnd.github+json" \
  "https://api.github.com/rate_limit" 2>/dev/null | jq -r '.resources.core.limit // 0')

if [ "$LIVE_LIMIT" != "5000" ]; then
  echo "ALERT: GitHub token rejected (rate-limit=$LIVE_LIMIT, expected 5000). Token revoked, expired, or scopes changed. Check https://github.com/settings/tokens?type=beta"
  exit 1
fi

# 2. Expiry check (only if GITHUB_TOKEN_EXPIRES is set)
if [ -z "$EXPIRES" ]; then
  echo "WARN: GITHUB_TOKEN_EXPIRES not set in secrets.env. Add 'export GITHUB_TOKEN_EXPIRES=YYYY-MM-DD' to enable expiry warnings."
  exit 0
fi

if ! [[ "$EXPIRES" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]] \
   || ! date -u -d "$EXPIRES" +%Y-%m-%d >/dev/null 2>&1; then
  echo "WARN: GITHUB_TOKEN_EXPIRES='$EXPIRES' is not a valid YYYY-MM-DD date."
  exit 0
fi

EXPIRES_TS=$(date -u -d "$EXPIRES" +%s)
DAYS_LEFT=$(( (EXPIRES_TS - NOW_TS) / 86400 ))
HUMAN_DATE=$(date -u -d "$EXPIRES" +'%b %d, %Y')

if [ "$DAYS_LEFT" -le 0 ]; then
  echo "ALERT: GitHub token EXPIRED $(( -DAYS_LEFT )) days ago ($HUMAN_DATE). Rotate immediately at https://github.com/settings/tokens?type=beta"
  exit 1
elif [ "$DAYS_LEFT" -le 7 ]; then
  echo "ALERT: GitHub token expires in $DAYS_LEFT days ($HUMAN_DATE). Rotate at https://github.com/settings/tokens?type=beta"
  exit 1
elif [ "$DAYS_LEFT" -le 14 ]; then
  echo "WARN: GitHub token expires in $DAYS_LEFT days ($HUMAN_DATE)"
  exit 0
else
  echo "OK: GitHub token valid, $DAYS_LEFT days remaining (expires $HUMAN_DATE)"
  exit 0
fi
