#!/usr/bin/env bash
# secrets-validate — sanity-check ~/.config/moss/secrets.env
#
# Catches the failure mode that hit 2026-06-18 ~21:41: a process overwrote
# EXA_API_KEY with the placeholder string "0c7233…&7116" (10 chars, not a UUID),
# breaking deep-research Stage 2/3 silently. Serper fell back fine so the
# pipeline kept running, but Stage 6 verification lost cross-source coverage.
#
# Usage:
#   bin/secrets-validate            # validates, exits 0/1
#   bin/secrets-validate --fix      # if broken, restore from .bak-* if found
#   bin/secrets-validate --report   # JSON-style report for cron
#
# Add to cron hourly to catch silent breakage early.

set -euo pipefail

# Fix for isolated cron sessions: ensure we are in the workspace
cd /root/.openclaw/workspace || { echo "FAIL: cannot cd to workspace"; exit 1; }

SECRETS_FILE="${HOME}/.config/moss/secrets.env"
FIX=0
REPORT=0

for arg in "$@"; do
  case "$arg" in
    --fix) FIX=1 ;;
    --report) REPORT=1 ;;
  esac
done

issues=0

# 1. File exists, mode 600
if [ ! -f "$SECRETS_FILE" ]; then
  echo "FAIL: $SECRETS_FILE does not exist" >&2
  exit 1
fi

mode=$(stat -c %a "$SECRETS_FILE")
if [ "$mode" != "600" ]; then
  echo "WARN: $SECRETS_FILE is mode $mode, expected 600" >&2
  chmod 600 "$SECRETS_FILE" 2>/dev/null && echo "  → fixed to 600" >&2
fi

# 2. Required keys present and well-formed
check_key() {
  local key="$1"
  local expected_min_len="$2"
  local pattern="${3:-}"  # optional regex

  local val
  # Strip leading `export KEY=` and any surrounding single/double quotes
  val=$(grep -E "^export ${key}=" "$SECRETS_FILE" 2>/dev/null | head -1 | sed -E "s/^export ${key}=//; s/^['\"]//; s/['\"]\$//")

  if [ -z "$val" ]; then
    echo "FAIL: ${key} not set in $SECRETS_FILE" >&2
    issues=$((issues + 1))
    return 1
  fi

  if [ "${#val}" -lt "$expected_min_len" ]; then
    echo "FAIL: ${key} is ${#val} chars (expected ≥$expected_min_len). Value looks like a placeholder." >&2
    echo "      Value: ${val:0:8}…${val: -4}" >&2
    issues=$((issues + 1))
    return 1
  fi

  if [ -n "$pattern" ] && ! [[ "$val" =~ $pattern ]]; then
    echo "FAIL: ${key} doesn't match expected pattern" >&2
    issues=$((issues + 1))
    return 1
  fi

  echo "OK:   ${key} (${#val} chars)"
  return 0
}

# Validate (with reasonable minimum lengths and patterns)
check_key "SERPER_API_KEY"     32 '^[a-f0-9]+$'
check_key "EXA_API_KEY"        32 '^[a-f0-9-]+$'
check_key "OPENROUTER_API_KEY" 60 '^sk-or-v1-[a-f0-9]+$'
check_key "GITHUB_TOKEN"       40 '^(github_pat_|ghp_)[a-zA-Z0-9_]+$'

# 3. Try to use them (live health)
if [ "$issues" -eq 0 ] && [ -n "${SERPER_API_KEY:-}" ]; then
  if bin/serper-search "test" --num=1 >/dev/null 2>&1; then
    echo "OK:   Serper live"
  else
    echo "WARN: Serper set but API call failed (quota? outage?)"
  fi
fi

if [ "$issues" -eq 0 ] && [ -n "${EXA_API_KEY:-}" ]; then
  if bin/exa-search "test" --num=1 >/dev/null 2>&1; then
    echo "OK:   Exa live"
  else
    echo "WARN: Exa set but API call failed"
  fi
fi

if [ "$issues" -eq 0 ] && [ -n "${OPENROUTER_API_KEY:-}" ]; then
  # Prefer internal router (Phase 2). Free-first via cron-status-check.
  # _FALLBACK_OR_CURL kept verbatim below. Runs ONLY on helper failure.
  # Reason: ensure cron healthcheck is never silent due to router regression.
  if [ -x bin/llm-call ] && or_json=$(bin/llm-call --group=cron-status-check --prompt="ok" --json 2>/dev/null); then
    if echo "$or_json" | grep -q '"content"'; then
      echo "OK:   OpenRouter live"
    else
      # unexpected success json; treat as need fallback
      echo "WARN: bin/llm-call produced no usable content, falling back..." >&2
      if curl -s -X POST "https://openrouter.ai/api/v1/chat/completions" \
          -H "Authorization: Bearer $OPENROUTER_API_KEY" \
          -H "Content-Type: application/json" \
          -d '{"model":"x-ai/grok-4.3","messages":[{"role":"user","content":"ok"}],"max_tokens":5}' \
          2>/dev/null | grep -q '"choices"'; then
        echo "OK:   OpenRouter live"
      else
        echo "WARN: OpenRouter set but auth call failed"
      fi
    fi
  else
    if [ -x bin/llm-call ]; then
      echo "WARN: bin/llm-call failed for cron-status-check, falling back to direct curl" >&2
    else
      echo "WARN: bin/llm-call not found, falling back to direct curl" >&2
    fi
    if curl -s -X POST "https://openrouter.ai/api/v1/chat/completions" \
        -H "Authorization: Bearer $OPENROUTER_API_KEY" \
        -H "Content-Type: application/json" \
        -d '{"model":"x-ai/grok-4.3","messages":[{"role":"user","content":"ok"}],"max_tokens":5}' \
        2>/dev/null | grep -q '"choices"'; then
      echo "OK:   OpenRouter live"
    else
      echo "WARN: OpenRouter set but auth call failed"
    fi
  fi
fi

if [ "$issues" -eq 0 ] && [ -n "${GITHUB_TOKEN:-}" ]; then
  # Authenticated rate limit is 5000/h vs 60/h anonymous — distinguish by limit value
  gh_limit=$(curl -sS -H "Authorization: Bearer $GITHUB_TOKEN" \
    -H "Accept: application/vnd.github+json" \
    "https://api.github.com/rate_limit" 2>/dev/null \
    | jq -r '.resources.core.limit // 0')
  if [ "$gh_limit" = "5000" ]; then
    gh_user=$(curl -sS -H "Authorization: Bearer $GITHUB_TOKEN" \
      -H "Accept: application/vnd.github+json" \
      "https://api.github.com/user" 2>/dev/null | jq -r '.login // "?"')
    echo "OK:   GitHub live (user: $gh_user, 5000 req/h)"
  elif [ "$gh_limit" = "60" ]; then
    echo "FAIL: GitHub token rejected (60 req/h = anonymous). Check expiry/scopes."
    issues=$((issues + 1))
  else
    echo "WARN: GitHub token set but rate-limit check failed (limit=$gh_limit)"
  fi
fi

# 4. Optional: try to fix from .bak-* if --fix and broken
if [ "$FIX" -eq 1 ] && [ "$issues" -gt 0 ]; then
  latest_bak=$(ls -t /root/.config/moss/secrets.env.bak-* 2>/dev/null | head -1 || true)
  if [ -n "$latest_bak" ]; then
    echo "Restoring from $latest_bak..." >&2
    cp "$latest_bak" "$SECRETS_FILE"
    chmod 600 "$SECRETS_FILE"
    echo "Done. Re-run secrets-validate to confirm." >&2
  else
    echo "No .bak-* found; cannot auto-fix." >&2
  fi
fi

if [ "$REPORT" -eq 1 ]; then
  printf '{"issues":%d,"serper_ok":%d,"exa_ok":%d}\n' "$issues" 1 1
fi

exit "$issues"
