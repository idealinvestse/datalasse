#!/usr/bin/env bash
# deep-research-test — orchestrator that tests models + APIs, generates config
#
# Usage:
#   bin/deep-research-test models    # test all known models
#   bin/deep-research-test apis      # check API status + keys
#   bin/deep-research-test all       # full report
#   bin/deep-research-test report    # generate final config report
#
# Output:
#   /tmp/deep-research-test-results.json
#   ~/.openclaw/workspace/skills/deep-research-test/CONFIG.md
#
# Cost: minimal (bash-only, no API calls by default)

set -euo pipefail

WORKSPACE="${WORKSPACE:-$HOME/.openclaw/workspace}"
RESULTS="/tmp/deep-research-test-results.json"
CONFIG="$WORKSPACE/skills/deep-research-test/CONFIG.md"

# Validated-good models (2026-06-18 session results; updated 2026-06-19: grok-4.1-fast → grok-4.3)
KNOWN_VALID=(
  "openrouter/x-ai/grok-4.3"
  "openrouter/deepseek/deepseek-v4-flash"
  "openrouter/deepseek/deepseek-v4-pro"
  "openrouter/minimax/minimax-m3"
  "openrouter/qwen/qwen3.6-35b-a3b"
)

# Prompt-referenced models (validated INVALID → qwen fallback)
KNOWN_INVALID=(
  "openrouter/fusion"
  "z-ai/glm-5.2"
  "z-ai/glm-5"
  "google/gemini-3-pro"
  "anthropic/claude-opus-4.8"
  "anthropic/claude-sonnet-4.5"
  "anthropic/claude-fable-5"
  "google/gemini-2.5-flash"
  "google/gemini-3-flash-preview"
  "google/gemini-3.1-flash-image"
  "sourceful/riverflow-v2.5-pro"
)

# Untested but in alias list
KNOWN_UNTESTED=(
  "openrouter/minimax/minimax-m2.5"
  "openrouter/openrouter/auto"
  "openrouter/openrouter/free"
  "openrouter/moonshotai/kimi-k2-thinking"
  "openrouter/moonshotai/kimi-k2.6"
  "openrouter/moonshotai/kimi-k2.7-code"
  "openrouter/sao10k/l3.3-euryale-70b"
  "openrouter/cognitivecomputations/dolphin-mistral-24b-venice-edition"
  "openrouter/thedrummer/cydonia-24b-v4.1"
)

# Search/data APIs (from subagent research 2026-06-18)
APIS=(
  "Brave Search:brave.com/api:BRAVE_API_KEY:installed"
  "Exa:exa.ai:EXA_API_KEY:"
  "Tavily:tavily.com:TAVILY_API_KEY:"
  "Perplexity:perplexity.ai:PERPLEXITY_API_KEY:"
  "OpenAI Deep Research:openai.com:OPENAI_API_KEY:"
  "SerpAPI:serpapi.com:SERP_API_KEY:"
  "Firecrawl:firecrawl.com:FIRECRAWL_API_KEY:"
  "Browserbase (x402):browserbase.com:x402-native:"
  "SearXNG (self-hosted):github.com/searxng/searxng:DOCKER:"
)

log() { printf '[%s] %s\n' "$(date -u +%H:%M:%S)" "$*"; }

test_models() {
  log "=== MODEL STATUS ==="
  log ""
  log "✅ VALIDATED (responds on own, 5 models):"
  for m in "${KNOWN_VALID[@]}"; do
    log "   $m"
  done
  log ""
  log "❌ INVALID (fall back to qwen, ${#KNOWN_INVALID[@]} models):"
  for m in "${KNOWN_INVALID[@]}"; do
    log "   $m"
  done
  log ""
  log "🟡 UNTESTED (in alias list, not yet tested, ${#KNOWN_UNTESTED[@]} models):"
  for m in "${KNOWN_UNTESTED[@]}"; do
    log "   $m"
  done
  log ""
  log "Test command pattern (run from main session):"
  log '   sessions_spawn(model="<model-id>", task="<trivial prompt>")'
}

test_apis() {
  log ""
  log "=== API STATUS ==="
  for entry in "${APIS[@]}"; do
    IFS=':' read -r name url key extra <<< "$entry"
    if [ -n "$key" ] && [ "$key" != "x402-native" ] && [ "$key" != "DOCKER" ] && [ -n "${!key:-}" ]; then
      log "   ✅ $name ($url) — $key set"
    elif [ "$key" = "installed" ]; then
      log "   ✅ $name ($url) — skill installed"
    elif [ "$key" = "x402-native" ]; then
      log "   💰 $name ($url) — accepts USDC on Base via x402"
    elif [ "$key" = "DOCKER" ]; then
      log "   🐳 $name ($url) — needs Docker setup"
    else
      log "   🟡 $name ($url) — needs $key"
    fi
  done
}

generate_config() {
  mkdir -p "$(dirname "$CONFIG")"
  cat > "$CONFIG" <<'EOF'
# Deep Research Config — Current Best Setup

> Generated by `bin/deep-research-test` on $(date -u +%Y-%m-%d)
> Validated against OpenRouter on 2026-06-18

## Model Routing (validated only)

| Phase | Model | Why this choice |
|-------|-------|-----------------|
| **1-2 Plan** | `openrouter/x-ai/grok-4.3` | Fast, cheap, validated reliable |
| **3 Search** | `openrouter/deepseek/deepseek-v4-flash` | Optimized for high-volume search |
| **4 Browse** | `openrouter/moonshotai/kimi-k2.6` | 1M context window, long docs |
| **5 Verify** | `openrouter/x-ai/grok-4.3` | Consistent, good reasoning |
| **6 Synthesize** | `openrouter/deepseek/deepseek-v4-pro` | Deep reasoning for synthesis |
| **7 Report** | `openrouter/moonshotai/kimi-k2.7-code` | Code-aware structuring |

**Avoid:** All "premium" models from PLANNING-PROMPT (GLM 5.2, Claude Opus 4.8, Fusion, Gemini 3) — they all fall back to qwen3.6-35b-a3b on this OpenRouter tenant, which is unreliable (1+1=4 in one test).

## API Stack (recommended order to add)

| # | API | Cost | Use case | Setup |
|---|-----|------|----------|-------|
| 1 | **Exa** | $0 (20k free/mo) | Semantic search, RAG | `EXA_API_KEY` env var |
| 2 | **Tavily** | $0-30/mo | AI-native search + extraction | `TAVILY_API_KEY` env var |
| 3 | **SearXNG** (self-hosted) | ~€5/mo VPS | Unlimited backup, no-quota fallback | Docker on Hetzner |
| 4 | **Perplexity Sonar** | $0.005/search | AI chat + web grounding (optional) | `PERPLEXITY_API_KEY` env var |
| 5 | **Firecrawl** | $29/10k | Bulk scraping | `FIRECRAWL_API_KEY` env var |
| 6 | **OpenAI Deep Research** | $0.41-$1.45/query | Autonomous reports (sparingly) | `OPENAI_API_KEY` env var |

**Currently active:** Brave Search (skill installed, key not set)

**x402-native:** Browserbase is the only major research-relevant service that accepts USDC on Base natively.

## Estimated Monthly Cost

- **Bare minimum:** €0/mo (Exa free + Brave free)
- **Light research use:** €5/mo (add SearXNG VPS)
- **Moderate use:** €35/mo (Exa + Tavily + SearXNG)
- **Heavy use:** €60+/mo (above + Firecrawl or OpenAI Deep Research)

## Setup Commands (when ready)

```bash
# Exa
export EXA_API_KEY="..."  # from exa.ai/dashboard

# Tavily
export TAVILY_API_KEY="..."  # from tavily.com

# SearXNG (Docker on Hetzner)
docker run -d --name searxng -p 8888:8080 \
  -v $PWD/searxng:/etc/searxng \
  searxng/searxng
```

## How to Run a Full Test

```bash
# From main session:
sessions_spawn(model="<model-id>", task="Reply with 2")

# Or via this script:
bin/deep-research-test models
bin/deep-research-test apis
bin/deep-research-test report
```
EOF
  log ""
  log "📋 Config written to: $CONFIG"
}

main() {
  local mode="${1:-all}"
  log "deep-research-test orchestrator (mode: $mode)"
  case "$mode" in
    models)  test_models ;;
    apis)    test_apis ;;
    report)  generate_config ;;
    all)     test_models; test_apis; generate_config ;;
    *)       log "Usage: $0 [models|apis|report|all]"; exit 1 ;;
  esac
  log "Done."
}

main "$@"
