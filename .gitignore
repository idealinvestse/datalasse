# ============================================================
# OpenClaw workspace — .gitignore
# ============================================================
# This workspace is an agent's home. Anything personal, sensitive,
# runtime-generated, or symlinked to another repo is excluded by
# default. Use `git add -f <path>` to force-include when needed.
# ============================================================

# ---------- Secrets & credentials ----------
# Never commit credentials, even in private repos.
.env
.env.*
!.env.example
**/credentials
**/credentials.json
**/*.key
**/*.pem
**/secrets*.env
**/secrets*.json
api_config.py
groq_wrapper.py

# ---------- Long-term memory (security) ----------
# MEMORY.md is loaded only in the main (direct) session and contains
# personal context that must NOT leak to shared contexts.
# Daily memory/ files are raw session logs — also sensitive.
MEMORY.md
memory/

# ---------- Internal strategy / audits ----------
# Strategy documents that contain business context.
STATUS_RESEARCH.md
decisions.md
config-audit-report.md

# ---------- Auto-generated runtime snapshots ----------
# Regenerated by cron every 5 min — never the source of truth.
STATUS.md
STATUS.json
.vps-snapshot-stamp
.vps-alert-log
.vps-alert-state
.vps-refresh.log

# Research pipeline runtime logs (regenerated continuously)
.research-*.log
.research-*-state
.fal-safety-audit-state
.fal-safety-audit.log

# ytmusic runtime logs (regenerated by cron + CLI)
.ytmusic-*.log

# ---------- Gateway runtime config ----------
# OpenClaw gateway state, tokens, internal config.
.openclaw/

# ---------- Symlinked project repos ----------
# These have their own .git repos. Don't nest.
projects/

# ---------- Greenfield / sandbox workspaces ----------
# datalasse-gf/ is a separate bootstrap workspace with its own .git
# (greenfield experiment). Keep the main workspace lean.
datalasse-gf/

# ---------- Research output snapshots ----------
# One-shot research outputs (timestamped catalogs, raw scrape dumps).
# Source for these lives in memory/research/ — keep repo lean.
research/

# ---------- Python build/test artifacts ----------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
.mypy_cache/
.ruff_cache/

# ---------- Node build artifacts ----------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---------- Transient directories ----------
tmp/

# Radicale cron backup log (regenerated daily)
.radicale-backup.log
incoming/

# ---------- Editor / OS ----------
.DS_Store
Thumbs.db
*.swp
*.swo
*.swn
*~
*.bak
*.orig
*.rej
.idea/
.vscode/
*.iml

# ---------- Misc artifacts ----------
# Stray file at workspace root (literal name: 5d})
# Some git versions mishandle `}` in patterns; the leading-slash +
# backslash form is the only one that matches reliably.
/5d\}
*.log                            # catch-all for any future .log
*.pid
*.seed
*.pid.lock

# ---------- Allow README / examples docs explicitly ----------
# (these are matched by docs/, examples/, skills/ but the patterns
# above could otherwise be too greedy — leave the rest to git)
.backups/

# Moss private (outside the security boundary — never commit)
.moss-private/

# Atomic-write temp files (cleanup if they escape the rename)
*.tmp.*

# Kill Tony pipeline: data + audio (för stor för git)
data/kill-tony/audio-cache/
data/kill-tony/transcripts/ep-*-chunks/
data/kill-tony/transcripts/ep-*.transcript.json
data/kill-tony/frames/
data/kill-tony/feed.xml
data/kill-tony/kill_tony.db
