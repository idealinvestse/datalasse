# MossRouter MCP — Phase 2b Environment
# Copy to .env or export. Testnet-first. No real mainnet money.

# Server
PORT=4023
MOSS_ROUTER_PORT=4022

# Bypass for full local tests (recommended for dev)
MOSS_MOCK=1
SKIP_PAYMENT=1

# Free tier per test key
FREE_TIER_DAILY=100

# x402 / Facilitator (defaults to testnet zero-auth)
# For testnet (default):
FACILITATOR_URL=https://x402.org/facilitator
NETWORK=eip155:84532
PAY_TO=0x000000000000000000000000000000000000dEaD

# For CDP (prod-capable, set keys to switch):
# CDP_API_KEY=your_cdp_key
# CDP_API_SECRET=your_cdp_secret
# FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402
# WARNING: NETWORK=eip155:8453 (Base mainnet) is YELLOW ZONE.
# Requires explicit owner approval before use with real funds. Default is testnet only.

# Redis (optional; if unset or unreachable -> in-memory fallback like Phase 2a)
# REDIS_URL=redis://localhost:6379
# REDIS_URL=rediss://user:pass@host:6380

# Langfuse v5 (optional; if unset -> no-op tracing, no crash)
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com   # EU default

# Tenant defaults (override via config or extend)
# (See config.example.json for more)

# MossRouter child inherits MOSS_MOCK etc automatically.
