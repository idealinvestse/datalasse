# Devin.ai credentials (v3)
# Copy to ~/.config/devin/devin.env and chmod 600
# Never commit real keys.

DEVIN_API_KEY=cog_your_service_user_key_here
DEVIN_ORG_ID=org-your-org-id-here
DEVIN_BASE_URL=https://api.devin.ai/v3
DEVIN_DEFAULT_MAX_ACU=10
DEVIN_TIMEOUT=30

# Optional: set to any truthy value for offline testing
# MOCK=1
