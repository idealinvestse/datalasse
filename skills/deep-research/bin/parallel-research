#!/usr/bin/env bash
# Parallel Research Orchestrator
# Spawns N OpenClaw sub-agents for parallel deep research.
# Usage:
#   bin/parallel-research --topics="T1,T2,T3" [--synthesize] [--output-dir=DIR] [--timeout=SEC]
#   bin/parallel-research --manifest=<json-file>

set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WORKSPACE="$(cd "$SCRIPT_DIR/.." && pwd)"

# --- defaults ---
DEFAULT_OUTPUT_DIR="$WORKSPACE/projects/mossfund/research/parallel"
DEFAULT_TIMEOUT=300
DEFAULT_MODEL="openrouter/deepseek/deepseek-v4-flash"

# --- parse args ---
TOPICS=""
MANIFEST=""
SYNTHESIZE=false
OUTPUT_DIR="$DEFAULT_OUTPUT_DIR"
TIMEOUT="$DEFAULT_TIMEOUT"
MODEL="$DEFAULT_MODEL"
COUNT=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --topics=*) TOPICS="${1#*=}"; shift ;;
    --manifest=*) MANIFEST="${1#*=}"; shift ;;
    --synthesize) SYNTHESIZE=true; shift ;;
    --output-dir=*) OUTPUT_DIR="${1#*=}"; shift ;;
    --output-dir) OUTPUT_DIR="$2"; shift 2 ;;
    --timeout=*) TIMEOUT="${1#*=}"; shift ;;
    --timeout) TIMEOUT="$2"; shift 2 ;;
    --count=*) COUNT="${1#*=}"; shift ;;
    --count) COUNT="$2"; shift 2 ;;
    --model=*) MODEL="${1#*=}"; shift ;;
    --model) MODEL="$2"; shift 2 ;;
    --help|-h) 
      echo "Usage: bin/parallel-research [options]"
      echo ""
      echo "Options:"
      echo "  --topics=\"T1,T2,T3\"     Comma-separated research topics"
      echo "  --manifest=<file>       JSON manifest with topics[] + metadata"
      echo "  --synthesize            Run synthesis after all agents complete"
      echo "  --output-dir=<dir>      Output directory (default: projects/mossfund/research/parallel/)"
      echo "  --timeout=<sec>         Per-agent timeout (default: 300)"
      echo "  --count=<N>             Max agents (default: all topics)"
      echo "  --model=<model>         Model for research agents"
      echo "  --help                  This help"
      echo ""
      echo "Output structure:"
      echo "  <output-dir>/manifest.json     — all topics + metadata"
      echo "  <output-dir>/topics/           — one file per topic"
      echo "  <output-dir>/run.log           — execution log"
      exit 0 ;;
    *) echo "Unknown: $1"; exit 1 ;;
  esac
done

# --- resolve topics ---
TOPIC_LIST=()
if [[ -n "$MANIFEST" ]]; then
  if [[ ! -f "$MANIFEST" ]]; then echo "Manifest not found: $MANIFEST"; exit 1; fi
  while IFS= read -r t; do TOPIC_LIST+=("$t"); done < <(jq -r '.topics[]' "$MANIFEST")
  if [[ -z "${OUTPUT_DIR:-}" ]]; then
    OUTPUT_DIR="$(jq -r '.output_dir // ""' "$MANIFEST")"
    [[ -z "$OUTPUT_DIR" || "$OUTPUT_DIR" == "null" ]] && OUTPUT_DIR="$DEFAULT_OUTPUT_DIR"
  fi
elif [[ -n "$TOPICS" ]]; then
  IFS=',' read -ra TMP <<< "$TOPICS"
  for t in "${TMP[@]}"; do
    t="$(echo "$t" | xargs)"
    [[ -n "$t" ]] && TOPIC_LIST+=("$t")
  done
else
  echo "Error: specify --topics or --manifest"
  exit 1
fi

# --- apply count limit ---
if [[ -n "$COUNT" ]]; then
  TOPIC_LIST=("${TOPIC_LIST[@]:0:$COUNT}")
fi

if [[ ${#TOPIC_LIST[@]} -eq 0 ]]; then
  echo "Error: no topics specified"
  exit 1
fi

# --- create output dirs ---
RUN_ID="run-$(date +%Y%m%d-%H%M%S)"
RUN_DIR="$OUTPUT_DIR/$RUN_ID"
TOPICS_DIR="$RUN_DIR/topics"
mkdir -p "$TOPICS_DIR"

echo "[$(date -u +%H:%M:%S)] Parallel research run: $RUN_ID" | tee "$RUN_DIR/run.log"
echo "[$(date -u +%H:%M:%S)] Topics: ${#TOPIC_LIST[@]}" | tee -a "$RUN_DIR/run.log"
echo "[$(date -u +%H:%M:%S)] Model: $MODEL" | tee -a "$RUN_DIR/run.log"
echo "[$(date -u +%H:%M:%S)] Timeout: ${TIMEOUT}s" | tee -a "$RUN_DIR/run.log"

# --- write manifest ---
cat > "$RUN_DIR/manifest.json" <<JSONEOF
{
  "run_id": "$RUN_ID",
  "created": "$(date -u -Iseconds)",
  "model": "$MODEL",
  "timeout_seconds": $TIMEOUT,
  "topics": [
$(for i in "${!TOPIC_LIST[@]}"; do
  t="${TOPIC_LIST[$i]}"
  SHORT=$(echo "$t" | sed 's/^---*//g' | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9 ]//g' | tr -s ' ' | head -c 60 | tr ' ' '-' | sed 's/-$//' | tr -d '\n')
  comma=""
  [[ $i -lt $((${#TOPIC_LIST[@]}-1)) ]] && comma=","
  echo "    {\"index\": $i, \"topic\": $(echo "$t" | jq -Rs .), \"output_file\": \"$(printf '%02d' $i)-${SHORT}.md\" }$comma"
done)
  ],
  "synthesize": $SYNTHESIZE,
  "output_dir": "$RUN_DIR"
}
JSONEOF

# --- write individual topic files ---
for i in "${!TOPIC_LIST[@]}"; do
  t="${TOPIC_LIST[$i]}"
  # Extract short label: first 60 chars of topic, sanitized
  SHORT=$(echo "$t" | sed 's/^---*//g' | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9 ]//g' | tr -s ' ' | head -c 60 | tr ' ' '-' | sed 's/-$//' | tr -d '\n')
  FNAME="$(printf '%02d' $i)-${SHORT}.md"
  p="${FNAME%.md}.md"
  OUTFILE="$TOPICS_DIR/$p"
  
  cat > "$OUTFILE" <<TOPICEOF
# Research Topic: $t

**Run:** $RUN_ID
**Index:** $i
**Created:** $(date -u -Iseconds)

## 🔧 Available Tools

You have TWO search tools available:

1. **web_search + web_fetch** — OpenClaw built-in search (general web)
2. **exec("bin/exa-search \"query\" --count=N")** — Exa AI neural/keyword search (better for business data, pricing, competitors, market research)

Use **both**! Start with Exa (exec) for initial deep search, then use web_fetch to read specific pages found via Exa.

## Research Instructions

Write your complete findings below in this file.
Required sections:
- Sammanfattning (Executive Summary, 3-5 meningar)
- Marknadsanalys (storlek, tillväxt, trender)
- Konkurrentanalys (namn, priser, styrkor/svagheter)
- Affärsmodellsrekommendation
- Revenue estimate (lägsta/realistiskt/aggressivt per månad)
- Genomförbarhet (1-10) och tid till första intäkt
- Confidence Audit

## Summary

## Key Sources

## Detailed Analysis

## Confidence Audit

TOPICEOF
done

echo "[$(date -u +%H:%M:%S)] Manifest written: $RUN_DIR/manifest.json" | tee -a "$RUN_DIR/run.log"
echo "[$(date -u +%H:%M:%S)] Topic files: $TOPICS_DIR/" | tee -a "$RUN_DIR/run.log"
echo ""
echo "=== PARALLEL RESEARCH READY ==="
echo "Run dir:  $RUN_DIR"
echo "Topics:   ${#TOPIC_LIST[@]}"
echo "Spawn command for agent:"
echo "  sessions_spawn x ${#TOPIC_LIST[@]} with prompts from manifest"
echo ""
echo "Output manifest for agent consumption:"
cat "$RUN_DIR/manifest.json" | jq '.'