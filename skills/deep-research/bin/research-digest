#!/usr/bin/env bash
# research-digest — daily research digest (Markdown + optional Telegram)
#
# Usage:
#   bin/research-digest [--telegram] [--json] [--date=YYYY-MM-DD]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=lib/research-state.sh
source "$SCRIPT_DIR/lib/research-state.sh"

TELEGRAM=0
JSON_OUT=0
DIGEST_DATE=""

usage() {
  sed -n '3,6p' "$0"
}

truncate_str() {
  local s="$1" max="${2:-120}"
  if [ "${#s}" -le "$max" ]; then echo "$s"; else echo "${s:0:$((max - 3))}..."; fi
}

ensure_fresh_status() {
  local age=999999
  if [ -f "$STATUS_JSON" ]; then
    local gen now_epoch gen_epoch
    gen=$(jq -r '.generated_at // empty' "$STATUS_JSON")
    if [ -n "$gen" ]; then
      now_epoch=$(date +%s)
      gen_epoch=$(iso_to_epoch "$gen")
      age=$((now_epoch - gen_epoch))
    fi
  fi
  if [ "$age" -gt 1800 ]; then
    "$SCRIPT_DIR/research-status" --quiet 2>/dev/null || true
  fi
}

next_even_hour_utc() {
  python3 <<'PY'
from datetime import datetime, timezone, timedelta
now = datetime.now(timezone.utc)
h = now.hour
next_h = h + (2 - h % 2) if h % 2 else h + 2
if next_h >= 24:
    d = now + timedelta(days=1)
    print(d.strftime("%Y-%m-%d") + " 00:00 UTC")
else:
    print(now.strftime("%Y-%m-%d") + f" {next_h:02d}:00 UTC")
PY
}

next_monday_9utc() {
  python3 <<'PY'
from datetime import datetime, timezone, timedelta
now = datetime.now(timezone.utc)
days = (7 - now.weekday()) % 7
if days == 0 and (now.hour, now.minute) >= (9, 0):
    days = 7
target = (now + timedelta(days=days)).replace(hour=9, minute=0, second=0, microsecond=0)
print(target.strftime("%Y-%m-%d %H:%M UTC"))
PY
}

next_mossfund_daily() {
  python3 <<'PY'
from datetime import datetime, timezone, timedelta
now = datetime.now(timezone.utc)
target = now.replace(hour=9, minute=0, second=0, microsecond=0)
if now >= target:
    target += timedelta(days=1)
print(target.strftime("%Y-%m-%d %H:%M UTC"))
PY
}

build_digest_json() {
  ensure_fresh_status
  research_ensure_dirs

  local feedback_json goals_json status_json prioritize_json
  feedback_json=$(feedback_read_json)
  goals_json=$(goals_read_json | jq '[.[] | select(.status == "active")]')

  if [ -f "$STATUS_JSON" ]; then
    status_json=$(jq '.' "$STATUS_JSON")
  else
    status_json='{"health":{"exa":"unknown","serper":"unknown"},"cache_hit_rate":0}'
  fi

  prioritize_json=$("$SCRIPT_DIR/research-prioritize" --json 2>/dev/null || echo '{"rankings":[]}')

  local runs_json
  if [ -d "$RUNS_DIR" ] && compgen -G "$RUNS_DIR/*.json" >/dev/null; then
    runs_json=$(jq -s 'sort_by(.timestamp) | reverse | .[0:5]' "$RUNS_DIR"/*.json 2>/dev/null || echo '[]')
  else
    runs_json='[]'
  fi

  python3 - "$runs_json" "$feedback_json" "$goals_json" "$status_json" "$prioritize_json" <<'PY'
import json, sys

runs, feedback, goals, status, prio = [json.loads(x) for x in sys.argv[1:6]]
fb_by_run = {f["run_id"]: f["rating"] for f in feedback}

top_insights = []
for r in runs:
    rid = r.get("run_id", "")
    top_insights.append({
        "run_id": rid,
        "question": r.get("question", ""),
        "cost": r.get("cost", 0),
        "rating": fb_by_run.get(rid),
        "summary": (r.get("summary") or "")[:120],
    })

goal_progress = []
for g in goals:
    total = g.get("total_steps") or 0
    answered = g.get("answered_steps") or 0
    steps = f"{answered}/{total}" if total > 0 else "—"
    goal_progress.append({
        "goal_id": g.get("id"),
        "question": g.get("question", ""),
        "steps": steps,
        "cost_so_far": g.get("cost_so_far", 0),
    })

suggested = []
for row in (prio.get("rankings") or [])[:3]:
    suggested.append({
        "goal_id": row.get("goal_id"),
        "question": row.get("question"),
        "score": row.get("score"),
        "new_priority": row.get("new_priority"),
    })

health_raw = status.get("health") or {}
exa = health_raw.get("exa", "unknown")
serper = health_raw.get("serper", "unknown")
cache = status.get("cache_hit_rate", 0)
try:
    cache_pct = round(float(cache) * 100, 1)
except (TypeError, ValueError):
    cache_pct = 0

health = {
    "exa": "driftstopp" if exa in ("down", "degraded") else exa,
    "serper": "live" if serper == "ok" else serper,
    "cache_hit_rate_pct": cache_pct,
}

out = {
    "top_insights": top_insights,
    "goal_progress": goal_progress,
    "suggested_next_steps": suggested,
    "health": health,
    "upcoming": {},
}
print(json.dumps(out))
PY
}

build_markdown() {
  local data="$1" date_str="$2"
  python3 - "$data" "$date_str" <<'PY'
import json, sys

data = json.loads(sys.argv[1])
date_str = sys.argv[2]

lines = [f"# Research Digest — {date_str}", ""]

lines.append("## Top insights")
if data["top_insights"]:
    for ins in data["top_insights"]:
        rating = f"★{ins['rating']}" if ins.get("rating") else "—"
        q = ins.get("question", "")
        cost = ins.get("cost", 0)
        summary = ins.get("summary") or "No summary"
        lines.append(f"- **{q}** — ${cost:.2f}, {rating} — {summary}")
else:
    lines.append("- No recent runs.")

lines.append("")
lines.append("## Goal progress")
if data["goal_progress"]:
    lines.append("| Goal | Steps | Cost |")
    lines.append("|------|-------|------|")
    for g in data["goal_progress"]:
        q = g.get("question", "")[:50]
        lines.append(f"| {q} | {g.get('steps', '—')} | ${float(g.get('cost_so_far', 0)):.2f} |")
else:
    lines.append("No active goals.")

lines.append("")
lines.append("## Suggested next steps")
if data["suggested_next_steps"]:
    for i, s in enumerate(data["suggested_next_steps"], 1):
        lines.append(f"{i}. [{s.get('goal_id')}] {s.get('question', '')} (score {s.get('score')})")
else:
    lines.append("No prioritized goals yet.")

lines.append("")
lines.append("## Health")
h = data["health"]
lines.append(f"- Exa: {h.get('exa')} · Serper: {h.get('serper')} · Cache: {h.get('cache_hit_rate_pct')}%")

lines.append("")
lines.append("## Upcoming")
up = data.get("upcoming") or {}
for k, v in up.items():
    lines.append(f"- {k}: {v}")

print("\n".join(lines))
PY
}

send_telegram() {
  local body="$1"
  if ! command -v openclaw >/dev/null 2>&1; then
    echo "Warning: openclaw not found; skipping Telegram delivery" >&2
    return 0
  fi
  local msg="$body"
  if [ "${#msg}" -gt 3500 ]; then
    msg="${msg:0:3497}..."
  fi
  openclaw message send --channel telegram --target 438805461 --message "$msg" >/dev/null 2>&1 || true
}

while [ $# -gt 0 ]; do
  case "$1" in
    --telegram) TELEGRAM=1 ;;
    --json) JSON_OUT=1 ;;
    --date=*) DIGEST_DATE="${1#*=}" ;;
    --help|-h) usage; exit 0 ;;
    *) echo "Unknown argument: $1" >&2; exit 1 ;;
  esac
  shift
done

research_ensure_dirs

if [ -z "$DIGEST_DATE" ]; then
  DIGEST_DATE=$(date -u +%Y-%m-%d)
fi

digest_data=$(build_digest_json)

watch_next=$(next_even_hour_utc)
metrics_next=$(next_monday_9utc)
mossfund_next=$(next_mossfund_daily)

digest_data=$(echo "$digest_data" | jq \
  --arg watch "research-watch: $watch_next" \
  --arg metrics "research-metrics: $metrics_next" \
  --arg mossfund "Mossfund daily: $mossfund_next" \
  '.upcoming = {($watch): $watch, ($metrics): $metrics, ($mossfund): $mossfund}')

# Fix upcoming structure - plan wants key: value pairs
digest_data=$(echo "$digest_data" | jq \
  --arg w "$watch_next" \
  --arg m "$metrics_next" \
  --arg f "$mossfund_next" \
  '.upcoming = {"research-watch": $w, "research-metrics": $m, "Mossfund daily": $f}')

md=$(build_markdown "$digest_data" "$DIGEST_DATE")

digest_file="$RESEARCH_DIR/digest-${DIGEST_DATE}.md"
atomic_write "$digest_file" "$md"

if [ "$JSON_OUT" -eq 1 ]; then
  echo "$digest_data" | jq --arg date "$DIGEST_DATE" --arg file "$digest_file" \
    '. + {date: $date, digest_path: $file}'
  exit 0
fi

echo "$md"

if [ "$TELEGRAM" -eq 1 ]; then
  send_telegram "$md"
fi