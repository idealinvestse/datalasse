#!/usr/bin/env bash
# research-prioritize — adaptive re-ranking of active research goals
#
# Usage:
#   bin/research-prioritize [--apply] [--json] [--weights=w1,w2,w3,w4]
#
# Score = w1*priority + w2*recency + w3*cost_efficiency + w4*feedback (all 0-1).
# new_priority = clamp(round(score * 4 + 1), 1, 5)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
LIB_DIR="$(dirname "$SCRIPT_DIR")/lib"
# shellcheck source=lib/research-state.sh
source "$LIB_DIR/research-state.sh"

APPLY=0
JSON_OUT=0
WEIGHTS="0.4,0.2,0.2,0.2"

usage() {
  sed -n '3,9p' "$0"
}

truncate_str() {
  local s="$1" max="${2:-40}"
  if [ "${#s}" -le "$max" ]; then echo "$s"; else echo "${s:0:$((max - 3))}..."; fi
}

validate_weights() {
  local w="$1"
  python3 - "$w" <<'PY'
import sys
parts = sys.argv[1].split(",")
if len(parts) != 4:
    print("Error: --weights requires 4 comma-separated values", file=sys.stderr)
    sys.exit(1)
try:
    vals = [float(x) for x in parts]
except ValueError:
    print("Error: weights must be numeric", file=sys.stderr)
    sys.exit(1)
if abs(sum(vals) - 1.0) > 0.01:
    print("Error: weights must sum to ~1.0", file=sys.stderr)
    sys.exit(1)
PY
}

compute_rankings() {
  local weights_csv="$1"
  local goals_json feedback_json
  goals_json=$(goals_read_json | jq '[.[] | select(.status == "active")]')
  feedback_json=$(feedback_read_json)

  python3 - "$weights_csv" "$goals_json" "$feedback_json" "$RUNS_DIR" <<'PY'
import json, sys, os
from datetime import datetime, timezone

weights = [float(x) for x in sys.argv[1].split(",")]
goals = json.loads(sys.argv[2])
feedback = json.loads(sys.argv[3])
runs_dir = sys.argv[4]

def iso_to_epoch(raw):
    try:
        if raw.count("-") >= 4 and "T" in raw:
            d, t = raw.split("T", 1)
            t = t.replace("-", ":")
            dt = datetime.fromisoformat(f"{d}T{t}").replace(tzinfo=timezone.utc)
        else:
            dt = datetime.fromisoformat(raw.replace("Z", "+00:00"))
        return int(dt.timestamp())
    except Exception:
        return 0

now = int(datetime.now(timezone.utc).timestamp())

def goal_feedback_avg(gid):
    ratings = [f["rating"] for f in feedback if f.get("goal_id") == gid]
    return sum(ratings) / len(ratings) if ratings else 3.0

def goal_last_run_epoch(goal):
    max_e = 0
    for rid in goal.get("runs") or []:
        rf = os.path.join(runs_dir, f"{rid}.json")
        ts = ""
        if os.path.isfile(rf):
            with open(rf) as f:
                data = json.load(f)
                ts = data.get("timestamp") or ""
        epoch = iso_to_epoch(ts) if ts else iso_to_epoch(rid)
        max_e = max(max_e, epoch)
    if max_e == 0:
        created = goal.get("created_at") or ""
        max_e = iso_to_epoch(created)
    return max_e

rankings = []
for g in goals:
    gid = g["id"]
    pri = g.get("priority", 3)
    cost = float(g.get("cost_so_far") or 0)
    last_e = goal_last_run_epoch(g)
    if last_e == 0:
        days = 999
    else:
        days = max(0, (now - last_e) // 86400)
    avg_rating = goal_feedback_avg(gid)

    priority_n = (pri - 1) / 4
    recency = 1 / (1 + days)
    cost_eff = 1 / (1 + cost)
    feedback_n = (avg_rating - 1) / 4

    score = (
        weights[0] * priority_n
        + weights[1] * recency
        + weights[2] * cost_eff
        + weights[3] * feedback_n
    )
    new_pri = max(1, min(5, round(score * 4 + 1)))

    rankings.append({
        "goal_id": gid,
        "question": g.get("question", ""),
        "score": round(score, 4),
        "old_priority": pri,
        "new_priority": new_pri,
        "days_since_last_run": days,
        "avg_rating": round(avg_rating, 2),
        "components": {
            "priority": round(priority_n, 4),
            "recency": round(recency, 4),
            "cost_efficiency": round(cost_eff, 4),
            "feedback": round(feedback_n, 4),
        },
    })

rankings.sort(key=lambda x: (-x["score"], x["goal_id"]))
print(json.dumps(rankings))
PY
}

while [ $# -gt 0 ]; do
  case "$1" in
    --apply) APPLY=1 ;;
    --json) JSON_OUT=1 ;;
    --weights=*) WEIGHTS="${1#*=}" ;;
    --help|-h) usage; exit 0 ;;
    *) echo "Unknown argument: $1" >&2; usage >&2; exit 1 ;;
  esac
  shift
done

validate_weights "$WEIGHTS"
research_ensure_dirs

rankings_json=$(compute_rankings "$WEIGHTS")
generated_at=$(date -u +%Y-%m-%dT%H:%M:%SZ)

w1=$(echo "$WEIGHTS" | cut -d, -f1)
w2=$(echo "$WEIGHTS" | cut -d, -f2)
w3=$(echo "$WEIGHTS" | cut -d, -f3)
w4=$(echo "$WEIGHTS" | cut -d, -f4)

output=$(jq -n \
  --arg generated_at "$generated_at" \
  --argjson w1 "$w1" --argjson w2 "$w2" --argjson w3 "$w3" --argjson w4 "$w4" \
  --argjson rankings "$rankings_json" \
  '{generated_at: $generated_at, weights: [$w1, $w2, $w3, $w4], rankings: $rankings}')

atomic_write "$PRIORITIZATION_FILE" "$(echo "$output" | jq -c .)"

if [ "$APPLY" -eq 1 ]; then
  now=$(date -u +%Y-%m-%dT%H:%M:%SZ)
  echo "$output" | jq -c '.rankings[]' | while read -r row; do
    gid=$(echo "$row" | jq -r '.goal_id')
    new_pri=$(echo "$row" | jq -r '.new_priority')
    goals_update_field "$gid" ".priority = $new_pri | .updated_at = \"$now\""
  done
fi

if [ "$JSON_OUT" -eq 1 ]; then
  echo "$output" | jq .
  exit 0
fi

echo "Prioritization — $generated_at"
echo ""
printf "| %-4s | %-16s | %-30s | %-7s | %-7s | %-5s | %-19s | %10s |\n" \
  "Rank" "Goal ID" "Question" "Old Pri" "New Pri" "Score" "Days since last run" "Avg rating"
printf "|------|------------------|--------------------------------|--------|---------|-------|---------------------|------------|\n"

rank=0
echo "$output" | jq -c '.rankings[0:10][]' | while read -r row; do
  rank=$((rank + 1))
  gid=$(echo "$row" | jq -r '.goal_id')
  q=$(truncate_str "$(echo "$row" | jq -r '.question')" 30)
  old=$(echo "$row" | jq -r '.old_priority')
  new=$(echo "$row" | jq -r '.new_priority')
  score=$(echo "$row" | jq -r '.score')
  days=$(echo "$row" | jq -r '.days_since_last_run')
  avg=$(echo "$row" | jq -r '.avg_rating')
  printf "| %-4s | %-16s | %-30s | %-7s | %-7s | %-5s | %-19s | %10s |\n" \
    "$rank" "$gid" "$q" "$old" "$new" "$score" "$days" "$avg"
done

total=$(echo "$output" | jq '.rankings | length')
echo ""
echo "Ranked $total active goal(s). Output: $PRIORITIZATION_FILE"