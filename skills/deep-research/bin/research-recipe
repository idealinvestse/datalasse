#!/usr/bin/env bash
# research-recipe — predefined research plan templates / enhanced queries
#
# Usage:
#   bin/research-recipe list
#   bin/research-recipe competitive-analysis "OpenAI vs xAI"
#   bin/research-recipe market-sizing "EU AI SaaS market 2026"
#
# Returns structured markdown (can feed into deep-research or planning).

set -euo pipefail

CMD="${1:-}"
shift || true
QUERY="$*"

list_recipes() {
  cat <<'LIST'
Available recipes:
  competitive-analysis
  market-sizing
  trend-discovery
  regulatory-landscape
LIST
}

case "$CMD" in
  list|"")
    list_recipes
    exit 0
    ;;
  competitive-analysis)
    if [ -z "$QUERY" ]; then
      echo "Usage: bin/research-recipe competitive-analysis \"X vs Y\"" >&2
      exit 1
    fi
    cat <<EOF
# Research Recipe: competitive-analysis
**Target:** $QUERY

**Enhanced focus query for decompose/search:**
Perform competitive analysis on $QUERY. Cover market position, features, pricing, strengths/weaknesses, customer segments, funding/traction, roadmap, and differentiation.

**Recommended depth:** deep or premium

**Key dimensions to investigate:**
- Product capabilities & tech
- Pricing & GTM
- Traction / users / revenue signals
- Team, funding, partnerships
- Risks & weaknesses
- Recent news / momentum

**Suggested output structure (in addition to standard):**
- Comparison table (features/pricing/positioning)
- Tier ranking (leader / challenger / niche)
- Recommended plays or counter-moves
EOF
    ;;
  market-sizing)
    if [ -z "$QUERY" ]; then
      echo "Usage: bin/research-recipe market-sizing \"TOPIC market 2026\"" >&2
      exit 1
    fi
    cat <<EOF
# Research Recipe: market-sizing
**Target:** $QUERY

**Enhanced focus query:**
Market size, growth rate (CAGR), TAM/SAM/SOM breakdown, key segments, drivers, inhibitors, major players, pricing benchmarks, and 2026-2028 projections for $QUERY.

**Recommended depth:** deep

**Key data points:**
- Current market size (USD/EUR) + sources
- Growth rates + forecasts
- Top 5-7 players with shares if available
- Unit economics / pricing examples
- Regulatory or macro tailwinds

**Suggested extras:**
Include bottom-up vs top-down estimates and confidence levels.
EOF
    ;;
  trend-discovery)
    if [ -z "$QUERY" ]; then
      echo "Usage: bin/research-recipe trend-discovery \"TOPIC\"" >&2
      exit 1
    fi
    cat <<EOF
# Research Recipe: trend-discovery
**Target:** $QUERY

**Enhanced focus query:**
Emerging trends, adoption signals, first-mover examples, hype vs reality, geographic differences, and timeline for mainstreaming around: $QUERY.

**Recommended depth:** deep

**Angles:**
- Earliest credible signals (papers, pilots, funding)
- Velocity indicators (searches, mentions, job posts)
- Skeptic/contrarian views
- Adjacent industries impacted
- 12-36 month outlook

**Suggested output:**
Timeline + tiered adoption forecast (early / growth / mature).
EOF
    ;;
  regulatory-landscape)
    if [ -z "$QUERY" ]; then
      echo "Usage: bin/research-recipe regulatory-landscape \"TOPIC\"" >&2
      exit 1
    fi
    cat <<EOF
# Research Recipe: regulatory-landscape
**Target:** $QUERY

**Enhanced focus query:**
Current and upcoming regulation, enforcement timelines, key jurisdictions (esp. EU/US), compliance requirements, and business impact for: $QUERY.

**Recommended depth:** deep

**Key sources to prioritize:**
- EUR-Lex / official EU docs
- National implementations
- Official guidance + consultations
- Industry responses / position papers

**Suggested output sections:**
- Timeline of rules (effective dates)
- Scope & obligations (who, what)
- Penalties & enforcement signals
- Practical compliance steps
EOF
    ;;
  *)
    echo "Unknown recipe: $CMD" >&2
    list_recipes >&2
    exit 1
    ;;
esac
