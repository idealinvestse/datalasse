#!/usr/bin/env bash
# research-improve — feedback pattern analysis for prompt-tuning suggestions
#
# Usage:
#   bin/research-improve [--json]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
LIB_DIR="$(dirname "$SCRIPT_DIR")/lib"
# shellcheck source=lib/research-state.sh
source "$LIB_DIR/research-state.sh"

JSON_OUT=0

usage() {
  sed -n '3,6p' "$0"
}

cache_hit_rate_pct() {
  local stats rate
  stats=$("$SCRIPT_DIR/cache-research" --stats 2>/dev/null || true)
  rate=$(echo "$stats" | grep -oE 'Hit rate: [0-9.]+%' | grep -oE '[0-9.]+' | head -1)
  if [ -z "$rate" ]; then echo "0"; else echo "$rate"; fi
}

enrich_feedback() {
  feedback_read_json | jq -c '.[]' | while read -r row; do
    local rid run_json provider qtype qlen question prov_stored
    rid=$(echo "$row" | jq -r '.run_id')
    prov_stored=$(echo "$row" | jq -r '.provider // empty')
    if run_json=$(run_get "$rid" 2>/dev/null); then
      provider=$(run_provider_class "$run_json")
      qtype=$(run_query_type "$run_json")
      question=$(echo "$run_json" | jq -r '.question // ""')
      qlen=$(question_length_bucket "$question")
    else
      case "$prov_stored" in
        serper-fallback) provider="exa-fallback" ;;
        serper) provider="serper-only" ;;
        exa) provider="exa" ;;
        *) provider="${prov_stored:-unknown}" ;;
      esac
      qtype="general"
      qlen="medium"
    fi
    echo "$row" | jq -c \
      --arg provider "$provider" \
      --arg query_type "$qtype" \
      --arg question_length "$qlen" \
      '. + {provider: $provider, query_type: $query_type, question_length: $question_length}'
  done | jq -s '.'
}

analyze_patterns() {
  local enriched="$1"
  local cache_rate="$2"
  python3 - "$enriched" "$cache_rate" <<'PY'
import json, sys, statistics

enriched = json.loads(sys.argv[1])
cache_rate = float(sys.argv[2])

groups = {}
for row in enriched:
    key = (row.get("provider", "unknown"), row.get("query_type", "general"), row.get("question_length", "medium"))
    groups.setdefault(key, []).append(row["rating"])

patterns = []
suggestions = []
for (provider, qtype, qlen), ratings in sorted(groups.items()):
    count = len(ratings)
    avg = sum(ratings) / count
    stddev = statistics.pstdev(ratings) if count > 1 else 0.0
    suggestion = ""
    if avg >= 4.0 and count >= 2:
        suggestion = f"default for {qtype} queries"
        suggestions.append(f"Use {provider} for {qtype} type (avg {avg:.1f}/5 over {count} runs)")
    elif avg <= 2.0 and count >= 2:
        suggestion = f"avoid or refine {qlen} queries on {provider}"
        suggestions.append(f"Avoid {qlen} queries on {provider} (avg {avg:.1f}/5 over {count} runs)")
    patterns.append({
        "provider": provider,
        "query_type": qtype,
        "question_length": qlen,
        "avg_rating": round(avg, 2),
        "count": count,
        "stddev": round(stddev, 2),
        "suggestion": suggestion,
    })

patterns = [p for p in patterns if p["suggestion"]]

if cache_rate == 0:
    suggestions.append("Cache hit rate 0% → consider pre-warming cache with common queries")

total = len(enriched)
avg_all = sum(r["rating"] for r in enriched) / total if total else 0
providers = sorted({r.get("provider", "unknown") for r in enriched})

out = {
    "generated_at": __import__("datetime").datetime.now(__import__("datetime").timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
    "patterns": patterns,
    "suggestions": suggestions,
    "global_stats": {
        "total_feedback": total,
        "avg_rating": round(avg_all, 2) if total else 0,
        "providers_covered": providers,
        "cache_hit_rate_pct": cache_rate,
    },
}
print(json.dumps(out))
PY
}

while [ $# -gt 0 ]; do
  case "$1" in
    --json) JSON_OUT=1 ;;
    --help|-h) usage; exit 0 ;;
    *) echo "Unknown argument: $1" >&2; exit 1 ;;
  esac
  shift
done

research_ensure_dirs

enriched=$(enrich_feedback)
cache_rate=$(cache_hit_rate_pct)
output=$(analyze_patterns "$enriched" "$cache_rate")

atomic_write "$IMPROVEMENTS_FILE" "$(echo "$output" | jq -c .)"

if [ "$JSON_OUT" -eq 1 ]; then
  echo "$output" | jq .
  exit 0
fi

echo "=== Research improvements ==="
echo ""
echo "$output" | jq -r '.suggestions[]? | if test("^Use") then "✓ " + . elif test("^Avoid") then "✗ " + . else "→ " + . end'
echo ""
echo "Global: $(echo "$output" | jq -r '.global_stats | "\(.total_feedback) ratings, avg \(.avg_rating)/5, cache \(.cache_hit_rate_pct)%"')"
echo "Output: $IMPROVEMENTS_FILE"